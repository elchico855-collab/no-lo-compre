{
  "name": "no-lo-compre",
  "version": "4.1.0",
  "description": "Tu mejor compra... es la que no hiciste.",
"author": "Alejandro Morquecho Martínez",
  "private": true,

  "main": "electron/main.js",

  "scripts": {
  "dev": "next dev --webpack",
  "electron": "electron .",
  "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
  "build": "next build",
  "start": "next start",
  "lint": "eslint",
  "pack": "electron-builder --dir",
  "dist": "electron-builder"
},

  "dependencies": {
    "firebase": "^12.16.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0"
  },

  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^38.1.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.5"

    
  }
  ,
"build": {
  "appId": "com.nolocompre.desktop",
  "productName": "NoLoCompré",
  "icon": "build/icon.ico",
  "artifactName": "${productName} Setup ${version}.${ext}",

  "copyright": "© 2026 NoLoCompré",

  "directories": {
    "output": "dist"
  },

  "files": [
    "**/*",
    "!dist/*"
  ],

  "win": {
    "target": "nsis",
    "icon": "build/icon.ico"
  },

  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "installerIcon": "build/icon.ico",
    "uninstallerIcon": "build/icon.ico",
    "installerHeaderIcon": "build/icon.ico"
  }
}
}